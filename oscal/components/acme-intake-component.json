    },
    "components": [
      {
        "uuid": "33333333-3333-4333-8333-333333333333",
        "type": "service",
        "title": "Patient Intake API (governed)",
        "description": "The starter Patient Intake API (VPC, Lambda, API Gateway, DynamoDB, S3) wrapped with a HIPAA GRC baseline: customer-managed KMS encryption, TLS-only transport, versioning, and least-privilege IAM. Compliance is enforced in Terraform and verified by an OPA policy gate in CI.",
        "props": [
          { "name": "implementation-point", "value": "external" }
        ],
        "control-implementations": [
          {
            "uuid": "44444444-4444-4444-8444-444444444444",
            "source": "https://csrc.nist.gov/publications/detail/sp/800-66/rev-2/final",
            "description": "HIPAA Security Rule technical safeguards, implemented per NIST SP 800-66 Rev. 2. Control IDs reference 45 CFR 164.3xx.",
            "implemented-requirements": [
              {
                "uuid": "55555555-5555-4555-8555-555555555501",
                "control-id": "hipaa-164.312.a.2.iv-s3",
                "description": "GAP-01: S3 uploads bucket holding PHI is encrypted at rest with a customer-managed KMS key (CMK), not the AWS-managed default. Enforced by aws_s3_bucket_server_side_encryption_configuration.uploads using sse_algorithm=aws:kms.",
                "props": [
                  { "name": "hipaa-control", "value": "164.312(a)(2)(iv)" },
                  { "name": "terraform-resource", "value": "aws_s3_bucket_server_side_encryption_configuration.uploads" },
                  { "name": "aws-resource", "value": "acme-health-intake-uploads-dea9e2dd" },
                  { "name": "kms-key", "value": "arn:aws:kms:us-east-1:669413339206:key/e15a3d27-7281-4e91-a67e-ec003fbafdad" }
                ],
                "links": [
                  { "href": "https://github.com/mansourjibrahim/cgep-app-starter/blob/main/policies/encryption.rego", "rel": "verification" }
                ]
              },
              {
                "uuid": "55555555-5555-4555-8555-555555555502",
                "control-id": "hipaa-164.312.a.2.iv-ddb",
                "description": "GAP-02: DynamoDB submissions table holding PHI is encrypted at rest with the customer-managed CMK via server_side_encryption on aws_dynamodb_table.intake.",
                "props": [
                  { "name": "hipaa-control", "value": "164.312(a)(2)(iv)" },
                  { "name": "terraform-resource", "value": "aws_dynamodb_table.intake" },
                  { "name": "aws-resource", "value": "arn:aws:dynamodb:us-east-1:669413339206:table/acme-health-intake-submissions-dea9e2dd" }
                ],
                "links": [
                  { "href": "https://github.com/mansourjibrahim/cgep-app-starter/blob/main/policies/dynamodb_encryption.rego", "rel": "verification" }
                ]
              },
              {
                "uuid": "55555555-5555-4555-8555-555555555503",
                "control-id": "hipaa-164.312.e.1",
                "description": "GAP-03: Transmission security. The uploads bucket policy denies any request where aws:SecureTransport is false, forcing TLS for all PHI access. Enforced by aws_s3_bucket_policy.uploads_tls.",
                "props": [
                  { "name": "hipaa-control", "value": "164.312(e)(1)" },
                  { "name": "terraform-resource", "value": "aws_s3_bucket_policy.uploads_tls" },
                  { "name": "aws-resource", "value": "acme-health-intake-uploads-dea9e2dd" }
                ],
                "links": [
                  { "href": "https://github.com/mansourjibrahim/cgep-app-starter/blob/main/policies/tls_required.rego", "rel": "verification" }
                ]
              },
              {
                "uuid": "55555555-5555-4555-8555-555555555504",
                "control-id": "hipaa-164.308.a.7",
                "description": "GAP-04: Contingency/recoverability. Versioning is enabled on the PHI uploads bucket so object overwrites and deletes are recoverable. Enforced by aws_s3_bucket_versioning.uploads.",
                "props": [
                  { "name": "hipaa-control", "value": "164.308(a)(7)" },
                  { "name": "terraform-resource", "value": "aws_s3_bucket_versioning.uploads" },
                  { "name": "aws-resource", "value": "acme-health-intake-uploads-dea9e2dd" }
                ],
                "links": [
                  { "href": "https://github.com/mansourjibrahim/cgep-app-starter/blob/main/policies/versioning.rego", "rel": "verification" }
                ]
              },
              {
                "uuid": "55555555-5555-4555-8555-555555555505",
                "control-id": "hipaa-164.312.a.1",
                "description": "GAP-07: Access control / least privilege. The Lambda execution role was scoped from dynamodb:* and s3:* wildcards down to dynamodb:PutItem, s3:PutObject, and the minimal KMS actions required for encrypted writes. Enforced by aws_iam_role_policy.lambda_inline.",
                "props": [
                  { "name": "hipaa-control", "value": "164.312(a)(1)" },
                  { "name": "terraform-resource", "value": "aws_iam_role_policy.lambda_inline" }
                ],
                "links": [
                  { "href": "https://github.com/mansourjibrahim/cgep-app-starter/blob/main/policies/least_privilege.rego", "rel": "verification" }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
